# ── Copy this file to .env in the project root for docker compose ─────────────

# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# PostgreSQL (used by Docker Compose)
POSTGRES_DB=plate
POSTGRES_USER=plate
POSTGRES_PASSWORD=plate

# App config
DAILY_GOAL_KCAL=2000

# CORS (comma-separated frontend origins, no wildcard)
CORS_ALLOWED_ORIGINS=http://localhost:5173
